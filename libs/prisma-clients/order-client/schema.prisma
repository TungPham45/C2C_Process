generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/@prisma/client/order"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://postgres:123456@postgres:5432/order_db"
}

model Voucher {
  id                Int               @id @default(autoincrement())
  shop_id           Int?
  code              String            @unique @db.VarChar(50)
  target_type       String            @default("all_buyers") @db.VarChar(30)
  discount_type     String            @db.VarChar(50)
  discount_value    Decimal           @db.Decimal(12, 2)
  min_spend         Decimal?          @default(0) @db.Decimal(12, 2)
  max_discount      Decimal?          @db.Decimal(12, 2)
  start_date        DateTime          @db.Timestamp(6)
  end_date          DateTime          @db.Timestamp(6)
  total_quantity    Int?
  used_count        Int?              @default(0)
  max_per_user      Int?              @default(1)
  status            String            @default("scheduled") @db.VarChar(20)
  created_at        DateTime?         @default(now()) @db.Timestamp(6)
  checkout_sessions CheckoutSession[]
  shop_orders       ShopOrder[]
  claims            UserVoucherClaim[]
  settlements       PlatformVoucherSettlement[]

  @@index([status, start_date, end_date], map: "idx_vouchers_status_time")
  @@map("vouchers")
}

model CartItem {
  id                 Int       @id @default(autoincrement())
  cart_id            Int
  shop_id            Int
  product_variant_id Int
  quantity           Int?      @default(1)
  created_at         DateTime? @default(now()) @db.Timestamp(6)
  updated_at         DateTime? @default(now()) @db.Timestamp(6)

  @@index([cart_id], map: "idx_cart_items_cart_id")
  @@map("cart_items")
}

model CheckoutSession {
  id                  Int               @id @default(autoincrement())
  user_id             Int
  total_payment       Decimal           @db.Decimal(12, 2)
  payment_method      String?           @db.VarChar(50)
  payment_status      String?           @default("unpaid") @db.VarChar(50)
  platform_voucher_id Int?
  created_at          DateTime?         @default(now()) @db.Timestamp(6)
  updated_at          DateTime?         @default(now()) @db.Timestamp(6)
  platform_voucher    Voucher?          @relation(fields: [platform_voucher_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  shop_orders         ShopOrder[]
  voucher_claims      UserVoucherClaim[]
  settlements         PlatformVoucherSettlement[]

  @@map("checkout_sessions")
}

model ShopOrder {
  id                       Int                         @id @default(autoincrement())
  checkout_session_id      Int
  shop_id                  Int
  subtotal                 Decimal                     @db.Decimal(12, 2)
  shipping_fee             Decimal                     @db.Decimal(12, 2)
  shop_voucher_id          Int?
  platform_discount_amount Decimal                     @default(0) @db.Decimal(12, 2)
  shipping_address         String
  status                   String?                     @default("pending") @db.VarChar(50)
  tracking_number          String?                     @unique @db.VarChar(100)
  carrier_name             String?                     @db.VarChar(100)
  created_at               DateTime?                   @default(now()) @db.Timestamp(6)
  updated_at               DateTime?                   @default(now()) @db.Timestamp(6)
  delivered_at             DateTime?                   @db.Timestamp(6)
  items                    OrderItem[]
  checkout_session         CheckoutSession             @relation(fields: [checkout_session_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  shop_voucher             Voucher?                    @relation(fields: [shop_voucher_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  voucher_claims           UserVoucherClaim[]
  settlements              PlatformVoucherSettlement[]
  seller_payout            SellerPayout?
  return_request           ReturnRequest?

  @@index([checkout_session_id], map: "idx_shop_orders_checkout_session_id")
  @@map("shop_orders")
}

model OrderItem {
  id                 Int       @id @default(autoincrement())
  shop_order_id      Int
  product_variant_id Int
  product_name       String    @db.VarChar(255)
  variant_details    Json?
  quantity           Int
  price_at_purchase  Decimal   @db.Decimal(12, 2)
  created_at         DateTime? @default(now()) @db.Timestamp(6)
  shop_order         ShopOrder @relation(fields: [shop_order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("order_items")
}

model UserVoucherClaim {
  id                  Int              @id @default(autoincrement())
  user_id             Int
  voucher_id          Int
  claimed_at          DateTime?        @default(now()) @db.Timestamp(6)
  is_used             Boolean?         @default(false)
  used_at             DateTime?        @db.Timestamp(6)
  checkout_session_id Int?
  shop_order_id       Int?
  
  voucher             Voucher          @relation(fields: [voucher_id], references: [id], onDelete: Cascade)
  checkout_session    CheckoutSession? @relation(fields: [checkout_session_id], references: [id], onDelete: SetNull)
  shop_order          ShopOrder?       @relation(fields: [shop_order_id], references: [id], onDelete: SetNull)

  @@index([user_id], map: "idx_user_voucher_claims_user")
  @@index([voucher_id], map: "idx_user_voucher_claims_voucher")
  @@index([is_used], map: "idx_user_voucher_claims_used")
  @@index([checkout_session_id], map: "idx_user_voucher_claims_session")
  @@index([shop_order_id], map: "idx_user_voucher_claims_order")
  @@map("user_voucher_claims")
}

model PlatformVoucherSettlement {
  id                  Int             @id @default(autoincrement())
  voucher_id          Int
  user_id             Int
  shop_order_id       Int
  checkout_session_id Int
  discount_amount     Decimal         @db.Decimal(12, 2)
  settled_amount      Decimal?        @default(0) @db.Decimal(12, 2)
  status              String          @default("pending") @db.VarChar(20)
  settled_at          DateTime?       @db.Timestamp(6)
  note                String?         @db.Text
  created_at          DateTime?       @default(now()) @db.Timestamp(6)

  voucher             Voucher         @relation(fields: [voucher_id], references: [id], onDelete: Cascade)
  shop_order          ShopOrder       @relation(fields: [shop_order_id], references: [id], onDelete: Cascade)
  checkout_session    CheckoutSession @relation(fields: [checkout_session_id], references: [id], onDelete: Cascade)

  @@index([voucher_id], map: "idx_platform_settlements_voucher")
  @@index([shop_order_id], map: "idx_platform_settlements_shop_order")
  @@index([status], map: "idx_platform_settlements_status")
  @@map("platform_voucher_settlements")
}

model SellerPayout {
  id                  Int             @id @default(autoincrement())
  shop_order_id       Int             @unique
  checkout_session_id Int
  shop_id             Int
  seller_user_id      Int
  order_amount        Decimal         @db.Decimal(12, 2)
  platform_fee        Decimal         @db.Decimal(12, 2)
  seller_amount       Decimal         @db.Decimal(12, 2)
  status              String          @default("holding") @db.VarChar(20)
  eligible_at         DateTime        @db.Timestamp(6)
  paid_at             DateTime?       @db.Timestamp(6)
  created_at          DateTime?       @default(now()) @db.Timestamp(6)

  shop_order          ShopOrder       @relation(fields: [shop_order_id], references: [id], onDelete: Cascade)

  @@index([status, eligible_at], map: "idx_seller_payouts_status_eligible")
  @@index([shop_id], map: "idx_seller_payouts_shop")
  @@index([seller_user_id], map: "idx_seller_payouts_seller")
  @@map("seller_payouts")
}

model ReturnRequest {
  id              Int       @id @default(autoincrement())
  shop_order_id   Int       @unique
  user_id         Int
  reason          String    @db.Text
  images          Json?
  video_url       String?
  status          String    @default("pending") @db.VarChar(50)
  admin_note      String?   @db.Text
  created_at      DateTime? @default(now()) @db.Timestamp(6)
  updated_at      DateTime? @default(now()) @db.Timestamp(6)

  shop_order      ShopOrder @relation(fields: [shop_order_id], references: [id], onDelete: Cascade)

  @@index([status], map: "idx_return_requests_status")
  @@index([user_id], map: "idx_return_requests_user")
  @@map("return_requests")
}
