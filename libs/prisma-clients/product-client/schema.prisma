// Product Service Prisma Schema
datasource db {
  provider = "postgresql"
  url      = "postgresql://postgres:123456@postgres:5432/product_db"
}

generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/@prisma/client/product"
}

model Shop {
  id          Int        @id @default(autoincrement())
  owner_id    Int?
  name        String?    @db.VarChar(255)
  slug        String?    @unique @db.VarChar(255)
  description String?    @db.Text
  logo_url    String?    @db.Text
  rating      Decimal?   @default(0) @db.Decimal(3, 2)
  status      String?    @default("pending") @db.VarChar(50)
  created_at  DateTime?  @default(now()) @db.Timestamp(6)
  updated_at  DateTime?  @default(now()) @db.Timestamp(6)

  products    Product[]
  categories  Category[]
  followers   ShopFollow[]

  @@map("shops")
}

model ShopFollow {
  id         Int       @id @default(autoincrement())
  shop_id    Int
  user_id    Int
  created_at DateTime? @default(now()) @db.Timestamp(6)

  shop       Shop      @relation(fields: [shop_id], references: [id], onDelete: Cascade)

  @@unique([shop_id, user_id], map: "uq_shop_follows_shop_user")
  @@index([shop_id], map: "idx_shop_follows_shop")
  @@index([user_id], map: "idx_shop_follows_user")
  @@map("shop_follows")
}

model Product {
  id            Int       @id @default(autoincrement())
  shop_id       Int
  category_id   Int
  name          String    @db.VarChar(255)
  slug          String?   @unique @db.VarChar(255)
  description   String?   @db.Text
  base_price    Decimal   @db.Decimal(12, 2)
  thumbnail_url String?   @db.Text
  rating        Decimal?  @default(0) @db.Decimal(3, 2)
  sold_count    Int?      @default(0)
  view_count    Int?      @default(0)
  status        String?   @default("pending_approval") @db.VarChar(50) // 'pending_approval', 'active', 'hidden', 'banned', 'rejected'
  moderation_note String? @db.Text
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  updated_at    DateTime? @default(now()) @db.Timestamp(6)

  shop          Shop      @relation(fields: [shop_id], references: [id], onDelete: Cascade)
  category      Category  @relation(fields: [category_id], references: [id])
  variants      ProductVariant[]
  images        ProductImage[]
  attribute_values ProductAttributeValue[]
  reviews       Review[]

  shop_categories Category[] @relation("ProductToShopCategory")

  @@map("products")
}

model Category {
  id         Int       @id @default(autoincrement())
  parent_id  Int?
  shop_id    Int?      
  name       String    @db.VarChar(255)
  slug       String?   @unique @db.VarChar(255)
  icon_url   String?   @db.Text
  level      Int?      @default(1)
  sort_order Int?      @default(0)
  is_active  Boolean?  @default(true)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)

  parent     Category?  @relation("CategoryToCategory", fields: [parent_id], references: [id], onDelete: SetNull)
  children   Category[] @relation("CategoryToCategory")
  shop       Shop?      @relation(fields: [shop_id], references: [id], onDelete: Cascade)
  products   Product[]
  attribute_defs AttributeDefinition[]

  shop_products Product[] @relation("ProductToShopCategory")

  @@map("categories")
}

model ProductVariant {
  id             Int       @id @default(autoincrement())
  product_id     Int
  sku            String?   @unique @db.VarChar(100)
  stock_quantity Int?      @default(0)
  price_override Decimal?  @db.Decimal(12, 2)
  attributes     Json?     // e.g. {"color": "Red", "size": "XL"}
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  updated_at     DateTime? @default(now()) @db.Timestamp(6)

  product        Product   @relation(fields: [product_id], references: [id], onDelete: Cascade)
  images         ProductImage[]

  @@map("product_variants")
}

model ProductImage {
  id          Int       @id @default(autoincrement())
  product_id  Int
  variant_id  Int?
  image_url   String    @db.Text
  is_primary  Boolean?  @default(false)
  sort_order  Int?      @default(0)

  product     Product         @relation(fields: [product_id], references: [id], onDelete: Cascade)
  variant     ProductVariant? @relation(fields: [variant_id], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model AttributeDefinition {
  id          Int       @id @default(autoincrement())
  category_id Int
  name        String    @db.VarChar(255)
  input_type  String?   @db.VarChar(50) // 'dropdown', 'text', 'number'
  is_required Boolean?  @default(false)
  sort_order  Int?      @default(0)

  category    Category           @relation(fields: [category_id], references: [id], onDelete: Cascade)
  options     AttributeOption[]
  values      ProductAttributeValue[]

  @@map("attribute_definitions")
}

model AttributeOption {
  id           Int       @id @default(autoincrement())
  attribute_id Int
  value_name   String    @db.VarChar(255)
  sort_order   Int?      @default(0)

  attribute    AttributeDefinition @relation(fields: [attribute_id], references: [id], onDelete: Cascade)
  values       ProductAttributeValue[]

  @@map("attribute_options")
}

model ProductAttributeValue {
  id                  Int       @id @default(autoincrement())
  product_id          Int
  attribute_id        Int
  attribute_option_id Int?
  custom_value        String?   @db.Text

  product             Product              @relation(fields: [product_id], references: [id], onDelete: Cascade)
  attribute           AttributeDefinition  @relation(fields: [attribute_id], references: [id], onDelete: Cascade)
  attribute_option    AttributeOption?     @relation(fields: [attribute_option_id], references: [id], onDelete: SetNull)

  @@unique([product_id, attribute_id])
  @@map("product_attribute_values")
}

model Review {
  id            Int       @id @default(autoincrement())
  user_id       Int
  product_id    Int
  shop_order_id Int
  rating        Int       // 1-5
  comment       String?   @db.Text
  media_urls    Json?     // ["url1", "url2"]
  seller_reply  String?   @db.Text
  replied_at    DateTime? @db.Timestamp(6)
  created_at    DateTime? @default(now()) @db.Timestamp(6)

  product       Product   @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([user_id, product_id, shop_order_id])
  @@map("reviews")
}
