generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/@prisma/client/auth"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://postgres:123456@postgres:5432/auth_db"
}

enum TransactionType {
  topup
  payment
  payout
  withdraw
  refund
  transfer_in
  transfer_out
  fee
}

enum TransactionStatus {
  pending
  completed
  failed
}

model User {
  id         Int       @id @default(autoincrement())
  email      String    @unique @db.VarChar(255)
  password   String    @db.VarChar(255)
  full_name  String?   @db.VarChar(255)
  phone      String?   @unique @db.VarChar(20)
  avatar_url String?
  role       String?   @default("user") @db.VarChar(50)
  status     String?   @default("active") @db.VarChar(50)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  first_order_at DateTime? @db.Timestamp(6)
  addresses  Address[]
  carts      Cart?
  wallet     Wallet?
  wallet_transactions WalletTransaction[]
  verification_codes VerificationCode[]
  notifications Notification[]

  @@index([email], map: "idx_users_email")
  @@map("users")
}

model VerificationCode {
  id         Int      @id @default(autoincrement())
  user_id    Int
  code       String   @db.VarChar(10)
  purpose    String   @db.VarChar(50) // 'REGISTER', 'RESET_PASSWORD'
  expires_at DateTime @db.Timestamp(6)
  is_used    Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamp(6)

  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id], map: "idx_verif_user_id")
  @@map("verification_codes")
}

model Address {
  id             Int       @id @default(autoincrement())
  user_id        Int
  recipient_name String    @db.VarChar(255)
  phone_number   String    @db.VarChar(20)
  province_code  String    @db.VarChar(10)
  ward_code      String    @db.VarChar(10)
  address_line   String    @db.Text
  label          String?   @db.VarChar(50)
  is_default     Boolean?  @default(false)
  status         String?   @default("active") @db.VarChar(50)
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  updated_at     DateTime? @default(now()) @db.Timestamp(6)
  user           User      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_addresses_user_id")
  @@index([is_default], map: "idx_addresses_is_default")
  @@map("addresses")
}

model Cart {
  id         Int       @id @default(autoincrement())
  user_id    Int       @unique
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("carts")
}

model Wallet {
  id           Int                 @id @default(autoincrement())
  user_id      Int                 @unique
  balance      Decimal?            @default(0) @db.Decimal(15, 2)
  created_at   DateTime?           @default(now()) @db.Timestamp(6)
  updated_at   DateTime?           @default(now()) @db.Timestamp(6)
  transactions WalletTransaction[]
  user         User                @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("wallets")
}

model WalletTransaction {
  id               Int               @id @default(autoincrement())
  wallet_id        Int
  user_id          Int
  transaction_type TransactionType
  amount           Decimal           @db.Decimal(15, 2)
  balance_before   Decimal           @db.Decimal(15, 2)
  balance_after    Decimal           @db.Decimal(15, 2)
  status           TransactionStatus @default(completed)
  reference_id     String?           @db.VarChar(100)
  reference_type   String?           @db.VarChar(50)
  payment_method   String?           @db.VarChar(50)
  description      String?           @db.Text
  created_at       DateTime          @default(now()) @db.Timestamp(6)
  completed_at     DateTime?         @db.Timestamp(6)
  wallet           Wallet            @relation(fields: [wallet_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user             User              @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([wallet_id, created_at], map: "idx_wallet_transactions_wallet_time")
  @@index([user_id, created_at], map: "idx_wallet_transactions_user_time")
  @@index([transaction_type, status], map: "idx_wallet_transactions_type_status")
  @@index([reference_id, reference_type], map: "idx_wallet_transactions_reference")
  @@map("wallet_transactions")
}

model Notification {
  id         Int       @id @default(autoincrement())
  user_id    Int
  title      String    @db.VarChar(255)
  message    String    @db.Text
  type       String?   @db.VarChar(50) // 'ORDER', 'SYSTEM', 'CHAT'
  link       String?   @db.Text
  is_read    Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id], map: "idx_notifications_user_id")
  @@map("notifications")
}
